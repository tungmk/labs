extract = .bash_history : CONTAINS : -i input.mpg -qscale:v 2 frames/frame
embed = .bash_history : CONTAINS : embed_dc.py frames/frame_
rebuild = .bash_history : CONTAINS : -framerate 30 -i frames/frame_
attack = .bash_history : CONTAINS : -i output/output.mpg -c:v mpeg2video
detect = .bash_history : CONTAINS : detect_dc.py output/attacked_frames/frame_
